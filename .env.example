# Mantle DeFAI Trader API Configuration
# Copy this file to .env and fill in the real values before running.

# Server
PORT=8000
HOST=0.0.0.0
DEBUG=false

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Binance API endpoints
BINANCE_API_URL=https://api.binance.com
DATA_API_URL=https://data-api.binance.vision

# Mantle Network
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_CHAIN_ID=5000

# General cache TTL (seconds) used by core/binance modules
CACHE_TTL=300

# SQLite cache TTL (seconds) used by db.py
DB_CACHE_TTL=900

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# IP whitelist for sensitive endpoints (comma separated)
IP_WHITELIST=127.0.0.1,::1

# Redis connection for data aggregator cache
REDIS_URL=redis://localhost:6379

# Data aggregator settings (seconds)
AGGREGATOR_CACHE_TTL=900
AGGREGATOR_REFRESH_INTERVAL=900

# MantleDeFAIRegistry Contract
REGISTRY_ADDRESS=0x...
REGISTRY_PRIVATE_KEY=0x...

# Symmetric key used to encrypt on-chain signal payloads (hex string)
SIGNAL_ENCRYPTION_KEY=...

# Moralis API key (used by moralis_client.py for on-chain data)
MORALIS_API_KEY=
